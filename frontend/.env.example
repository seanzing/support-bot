# =============================================================================
# ZING Support Agent - Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# For production, copy to .env.production

# Backend API Base URL
# Development: /support (uses Vite proxy to localhost:8001)
# Production: https://zing-customer-support-agent-production.up.railway.app/support
VITE_SUPPORT_API_BASE=/support

# ChatKit API URL (usually same as API base + /chatkit)
# Only needed if different from API base
# VITE_SUPPORT_CHATKIT_API_URL=https://your-backend.railway.app/support/chatkit

# Customer Context API URL
# Only needed if different from API base
# VITE_SUPPORT_CUSTOMER_URL=https://your-backend.railway.app/support/customer

# Ticket API URL
# Only needed if different from API base
# VITE_SUPPORT_TICKET_URL=https://your-backend.railway.app/support/ticket

# Upload API URL
# Development: Uses Vite proxy (same as API base + /upload)
# Production: Uses Vercel serverless proxy at /api/support/upload to avoid CORS issues
# The proxy routes: Browser → Vercel (same-origin) → Railway (server-to-server)
VITE_SUPPORT_UPLOAD_URL=/api/support/upload

# OpenAI ChatKit Domain Key
# Development: use any placeholder value (e.g., domain_pk_localhost_dev)
# Production: Register at https://platform.openai.com/settings/organization/security/domain-allowlist
VITE_SUPPORT_CHATKIT_API_DOMAIN_KEY=domain_pk_localhost_dev

# Custom greeting message (optional)
# VITE_SUPPORT_GREETING=Welcome to ZING Support! How can I help you today?
