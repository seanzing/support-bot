# =============================================================================
# ZING Support Agent - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-api-key-here

# SMTP2GO API Key (required for email/ticket creation)
# Get yours at: https://www.smtp2go.com/
SMTP2GO_API_KEY=api-your-smtp2go-api-key-here
# Note: Sender and inbox emails are hardcoded in app/hubspot_integration.py

# AI Model to use (optional, defaults to gpt-5.1)
ZING_SUPPORT_MODEL=gpt-5.1

# Server Configuration
PORT=8001
HOST=0.0.0.0

# Environment
ENVIRONMENT=development

# =============================================================================
# CORS Configuration (required for production)
# =============================================================================
# Comma-separated list of allowed origins
# Development: http://localhost:5171
# Production: https://support.zing-work.com,https://zing-work.com
ALLOWED_ORIGINS=http://localhost:5171,http://localhost:3000
